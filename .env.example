# Copy this file to .env and fill in real values before running docker compose.
# Never commit the real .env file.

# Public hostname listeners will use (set up in Nginx Proxy Manager)
ICECAST_HOSTNAME=radio.yourdomain.com

# Icecast passwords - generate strong random values, e.g. `openssl rand -hex 16`
ICECAST_SOURCE_PASSWORD=changeme-source
ICECAST_RELAY_PASSWORD=changeme-relay
ICECAST_ADMIN_PASSWORD=changeme-admin
ICECAST_ADMIN_USER=admin

# Absolute path on the ZimaOS host to your music library (mixed mp3/flac/etc)
MUSIC_DIR=/DATA/Media/Music

# Name of the existing Docker network Nginx Proxy Manager is attached to,
# so NPM can reach the icecast container by name. Check with:
#   docker network ls
NPM_NETWORK=npm_default
